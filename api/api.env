# API Server Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
STATIC_PORT=8000

# Email Provider ('console' for development, 'smtp' for production)
EMAIL_PROVIDER=console

# SMTP Configuration
# Do not store real credentials in this file.
# In production, these values are injected at runtime from Azure Key Vault.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Sender Email Address
EMAIL_FROM=noreply@embodied-mind.org

# Feedback persistence ('none' or 'mariadb')
FEEDBACK_STORE_PROVIDER=mariadb

# MariaDB configuration (required when FEEDBACK_STORE_PROVIDER=mariadb)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=witchcraft_api
DB_PASSWORD=Rand0m.Witchcraft
DB_NAME=witchcraft_feedback

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://web.witchcraft-and-wizardry.school

# CORS handling in API app (production defaults to false in code)
APP_ENABLE_CORS=false
