{
  "name": "web-witchcraft-and-wizardry.school",
  "version": "1.0.0",
  "type": "module",
  "description": "Web Witchcraft and Wizardry is a free, open-source, self-paced online course for learning web development. It covers HTML, CSS, and JavaScript, and is designed to be accessible to learners of all backgrounds and skill levels.",
  "scripts": {
    "build": "node bin/build-by-folder.js",
    "format": "node bin/format-by-folder.js",
    "format:html": "node bin/format-by-folder.js",
    "format:css": "node bin/format-by-folder.js",
    "format:js": "node bin/format-by-folder.js",
    "format:check": "node bin/format-by-folder.js",
    "start": "node bin/start-by-folder.js",
    "dev": "node bin/start-by-folder.js",
    "api": "node api/server.js",
    "api:prod": "NODE_ENV=production node api/server.js",
    "tests": "node bin/run-tests-by-folder.js",
    "tests:all": "node bin/run-tests-by-folder.js . -x lessons diagnostics",
    "tests:continue": "node bin/run-tests-by-folder.js . -c -x lessons diagnostics",
    "tests:full": "node bin/run-tests-by-folder.js . -x lessons diagnostics",
    "tests:quick": "node bin/run-tests-by-folder.js . -q -x lessons diagnostics",
    "tests:wave": "node bin/run-tests-by-folder.js . -w -x lessons diagnostics",
    "tests:api": "newman run api/postman-collection.json -e api/postman-environment.json --color on --reporters cli,json --reporter-json-export api/diagnostics/test-results/postman.json"
  },
  "keywords": [
    "html",
    "css",
    "javascript",
    "learning",
    "web development",
    "online course",
    "open source"
  ],
  "author": "Edmund Mulligan",
  "license": "MIT",
  "engines": {
    "node": ">=22.19.0"
  },
  "devDependencies": {
    "glob": "^13.0.6",
    "http-server": "^14.1.1",
    "jshint": "^2.13.6",
    "mustache": "^4.2.0",
    "newman": "^6.2.2",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "@isaacs/brace-expansion": ">=5.0.1",
    "ajv": ">=8.18.0",
    "basic-ftp": ">=6.0.1",
    "brace-expansion": ">=5.0.6",
    "broken-link-checker": "^0.7.8",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "express": "^5.2.1",
    "flatted": ">=3.4.2",
    "follow-redirects": ">=1.16.0",
    "html-validate": "^11.1.0",
    "jsonpath": ">=1.3.0",
    "lodash": ">=4.18.0",
    "minimatch": ">=10.2.3",
    "nodemailer": "^8.0.7",
    "pa11y": "^9.1.1",
    "picomatch": ">=2.3.2",
    "playwright": "^1.60.0",
    "qs": ">=6.14.2",
    "robot-directives": ">=0.3.0",
    "robots-txt-guard": ">=1.0.2",
    "stylelint": "^17.11.1",
    "stylelint-config-standard": "^40.0.0",
    "text-readability": "^1.1.1",
    "tmp": ">=0.2.4",
    "tough-cookie": ">=4.1.3",
    "underscore": ">=1.13.8",
    "undici": ">=8.3.0",
    "uuid": ">=14.0.0"
  },
  "overrides": {
    "robots-txt-guard": ">=1.0.2",
    "robot-directives": ">=0.3.0",
    "tough-cookie": ">=4.1.3",
    "tmp": ">=0.2.4",
    "uuid": ">=14.0.0",
    "handlebars": ">=4.7.9",
    "jose": ">=5.0.0",
    "node-forge": ">=1.3.4",
    "flatted": ">=3.4.2",
    "lodash": ">=4.18.0",
    "underscore": ">=1.13.8",
    "minimatch": ">=10.2.3",
    "qs": ">=6.14.2",
    "useragent": ">=2.3.0"
  }
}
