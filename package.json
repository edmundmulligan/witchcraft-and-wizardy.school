{
  "name": "web-witchcraft-and-wizardry.school",
  "version": "1.0.0",
  "type": "module",
  "description": "Web Witchcraft and Wizardry is a free, open-source, self-paced online course for learning web development. It covers HTML, CSS, and JavaScript, and is designed to be accessible to learners of all backgrounds and skill levels.",
  "scripts": {
    "build": "bin/generate-colours-from-css.py web/styles/definitions/colours.css artwork/common/colours.tex && bin/generate-web-backgrounds.py && bin/generate-all-images.sh && node bin/build-lessons.js && npm run format",
    "format": "prettier --write --ignore-path .prettierignore \"**/*.{css,js}\" && node bin/fix-html-format.js web",
    "format:html": "node bin/fix-html-format.js .",
    "format:css": "prettier --write --ignore-path .prettierignore \"**/*.css\"",
    "format:js": "prettier --write --ignore-path .prettierignore \"**/*.js\"",
    "format:check": "prettier --check --ignore-path .prettierignore \"**/*.{css,js}\"",
    "start": "http-server . -p 8000 -c-1",
    "dev": "http-server . -p 8000 -c-1",
    "api": "node api/server.js",
    "api:prod": "NODE_ENV=production node api/server.js",
    "tests": "node bin/run-tests-by-folder.js",
    "test": "node bin/run-all-tests.js . -x lessons diagnostics",
    "test:continue": "node bin/run-all-tests.js . -c -x lessons diagnostics",
    "test:full": "node bin/run-all-tests.js . -x lessons diagnostics",
    "test:quick": "node bin/run-all-tests.js . -q -x lessons diagnostics",
    "test:wave": "node bin/run-all-tests.js . -w -x lessons diagnostics"
  },
  "keywords": [
    "html",
    "css",
    "javascript",
    "learning",
    "web development",
    "online course",
    "open source"
  ],
  "author": "Edmund Mulligan",
  "license": "MIT",
  "devDependencies": {
    "glob": "^13.0.6",
    "http-server": "^14.1.1",
    "mustache": "^4.2.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "@isaacs/brace-expansion": ">=5.0.1",
    "ajv": ">=8.18.0",
    "basic-ftp": ">=5.2.2",
    "brace-expansion": ">=1.1.13",
    "broken-link-checker": "^0.7.8",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "eslint": "^10.3.0",
    "express": "^4.21.2",
    "flatted": ">=3.4.2",
    "follow-redirects": ">=1.16.0",
    "html-validate": "^10.15.0",
    "minimatch": ">=10.2.3",
    "nodemailer": "^6.9.17",
    "pa11y": "^9.1.1",
    "picomatch": ">=2.3.2",
    "playwright": "^1.59.1",
    "qs": ">=6.14.2",
    "robots-txt-guard": ">=1.0.2",
    "stylelint": "^17.10.0",
    "stylelint-config-standard": "^40.0.0",
    "text-readability": "^1.1.1",
    "tmp": ">=0.2.4",
    "tough-cookie": ">=4.1.3",
    "undici": ">=8.1.0",
    "uuid": ">=14.0.0"
  },
  "overrides": {
    "robots-txt-guard": ">=1.0.2",
    "tough-cookie": ">=4.1.3",
    "tmp": ">=0.2.4",
    "uuid": ">=14.0.0"
  }
}
