# Environment Configuration for Web Witchcraft and Wizardry API
# Copy this file to .env and configure your settings

# ============================================================================
# DEVELOPMENT MODE (Recommended for testing)
# ============================================================================
# Logs emails to console instead of sending real emails
NODE_ENV=development
EMAIL_PROVIDER=console

# ============================================================================
# PRODUCTION MODE (Only for production deployment)
# ============================================================================
# Uncomment and configure these settings for production

# NODE_ENV=production
# EMAIL_PROVIDER=smtp

# SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password
# EMAIL_FROM=noreply@embodied-mind.org

# Server Configuration
# PORT=3000
# STATIC_PORT=8000

# ============================================================================
# Email Provider Examples
# ============================================================================

# Gmail (requires App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false

# Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false

# Custom SMTP
# SMTP_HOST=mail.your-domain.com
# SMTP_PORT=587
# SMTP_SECURE=false
