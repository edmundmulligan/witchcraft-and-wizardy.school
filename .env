# API Server Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
STATIC_PORT=8000

# Email Provider ('console' for development, 'smtp' for production)
EMAIL_PROVIDER=smtp

# SMTP Configuration (for production - not used in development with console provider)
# Port 465: Use SMTP_SECURE=true (SSL/TLS from start)
# Port 587: Use SMTP_SECURE=false (STARTTLS)
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=admin@embodied-mind.org
SMTP_PASS=Rand0m.Admin

# Sender Email Address
EMAIL_FROM=admin@embodied-mind.org

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://web.witchcraft-and-wizardry.school
